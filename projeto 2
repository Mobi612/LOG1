    /* Carrega os dados salvos quando o programa abre */
    carregar_veiculos();
    carregar_clientes();
    carregar_locacoes();

    printf("Sistema de Locadora de Veiculos carregado!\n");
    printf("Veiculos: %d | Clientes: %d | Locacoes: %d\n",
