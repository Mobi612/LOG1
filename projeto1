/*
 * Sistema de Gerenciamento de Locadora de Veículos
 * Linguagem: C
 * Funcionalidades: Veículos, Clientes, Locações, Relatórios
 * Persistência: Arquivos binários
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

/* ===================== CONSTANTES ===================== */
#define MAX_VEICULOS   100
#define MAX_CLIENTES   100
#define MAX_LOCACOES   200

#define ARQ_VEICULOS   "veiculos.dat"
#define ARQ_CLIENTES   "clientes.dat"
#define ARQ_LOCACOES   "locacoes.dat"

/* ===================== STRUCTS ===================== */

typedef struct {
    int    id;
    char   placa[10];
    char   modelo[50];
    char   marca[50];
    int    ano;
    float  diaria;
    int    disponivel; /* 1 = disponível, 0 = alugado */
} Veiculo;

typedef struct {
    int  id;
    char nome[80];
    char cnh[20];
    char telefone[20];
} Cliente;

typedef struct {
    int   id;
    int   id_veiculo;
    int   id_cliente;
    char  data_retirada[20];
    char  data_devolucao_prev[20];
    char  data_devolucao_real[20];
    int   dias;
    float valor_total;
    int   ativa; /* 1 = em andamento, 0 = encerrada */
} Locacao;

/* ===================== VARIÁVEIS GLOBAIS ===================== */

Veiculo  veiculos[MAX_VEICULOS];
Cliente  clientes[MAX_CLIENTES];
Locacao  locacoes[MAX_LOCACOES];

int total_veiculos = 0;
int total_clientes = 0;
int total_locacoes = 0;

/* ===================== PROTÓTIPOS ===================== */

/* Utilitários */
void   limpar_tela(void);
void   pausar(void);
void   data_hoje(char *buf, int tamanho);
void   limpar_buffer(void);

/* Persistência */
void   salvar_veiculos(void);
void   carregar_veiculos(void);
void   salvar_clientes(void);
void   carregar_clientes(void);
void   salvar_locacoes(void);
void   carregar_locacoes(void);

/* Veículos */
void   menu_veiculos(void);
void   cadastrar_veiculo(void);
void   listar_veiculos(void);
Veiculo *buscar_veiculo_placa(const char *placa);
Veiculo *buscar_veiculo_id(int id);

/* Clientes */
void    menu_clientes(void);
void    cadastrar_cliente(void);
void    listar_clientes(void);
Cliente *buscar_cliente_cnh(const char *cnh);
Cliente *buscar_cliente_id(int id);

/* Locações */
void   menu_locacoes(void);
void   registrar_aluguel(void);
void   registrar_devolucao(void);
void   listar_locacoes_ativas(void);

/* Relatórios */
void   menu_relatorios(void);
void   relatorio_veiculos_disponiveis(void);
void   relatorio_historico_locacoes(void);

/* Menu principal */
void   menu_principal(void);

/* ===================== UTILITÁRIOS ===================== */

void limpar_tela(void) {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}

void pausar(void) {
    printf("\nPressione ENTER para continuar...");
    limpar_buffer();
    getchar();
}

void data_hoje(char *buf, int tamanho) {
    time_t t = time(NULL);
    struct tm *tm_info = localtime(&t);
    strftime(buf, tamanho, "%d/%m/%Y", tm_info);
}

void limpar_buffer(void) {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

/* ===================== PERSISTÊNCIA ===================== */

void salvar_veiculos(void) {
    FILE *f = fopen(ARQ_VEICULOS, "wb");
    if (f == NULL) {
        printf("[ERRO] Nao foi possivel salvar veiculos.\n");
        return;
    }
    fwrite(&total_veiculos, sizeof(int), 1, f);
    fwrite(veiculos, sizeof(Veiculo), total_veiculos, f);
    fclose(f);
}

void carregar_veiculos(void) {
    FILE *f = fopen(ARQ_VEICULOS, "rb");
    if (f == NULL) return; /* Arquivo ainda não existe */
    fread(&total_veiculos, sizeof(int), 1, f);
    fread(veiculos, sizeof(Veiculo), total_veiculos, f);
    fclose(f);
}

void salvar_clientes(void) {
    FILE *f = fopen(ARQ_CLIENTES, "wb");
    if (f == NULL) {
        printf("[ERRO] Nao foi possivel salvar clientes.\n");
        return;
    }
    fwrite(&total_clientes, sizeof(int), 1, f);
    fwrite(clientes, sizeof(Cliente), total_clientes, f);
    fclose(f);
}

void carregar_clientes(void) {
    FILE *f = fopen(ARQ_CLIENTES, "rb");
    if (f == NULL) return;
    fread(&total_clientes, sizeof(int), 1, f);
    fread(clientes, sizeof(Cliente), total_clientes, f);
    fclose(f);
}

void salvar_locacoes(void) {
    FILE *f = fopen(ARQ_LOCACOES, "wb");
    if (f == NULL) {
        printf("[ERRO] Nao foi possivel salvar locacoes.\n");
        return;
    }
    fwrite(&total_locacoes, sizeof(int), 1, f);
    fwrite(locacoes, sizeof(Locacao), total_locacoes, f);
    fclose(f);
}

void carregar_locacoes(void) {
    FILE *f = fopen(ARQ_LOCACOES, "rb");
    if (f == NULL) return;
    fread(&total_locacoes, sizeof(int), 1, f);
    fread(locacoes, sizeof(Locacao), total_locacoes, f);
    fclose(f);
}

/* ===================== MÓDULO DE VEÍCULOS ===================== */

Veiculo *buscar_veiculo_placa(const char *placa) {
    int i;
    for (i = 0; i < total_veiculos; i++) {
        if (strcmp(veiculos[i].placa, placa) == 0)
            return &veiculos[i];
    }
    return NULL;
}

Veiculo *buscar_veiculo_id(int id) {
    int i;
    for (i = 0; i < total_veiculos; i++) {
        if (veiculos[i].id == id)
            return &veiculos[i];
    }
    return NULL;
}

void cadastrar_veiculo(void) {
    if (total_veiculos >= MAX_VEICULOS) {
        printf("[AVISO] Limite de veiculos atingido.\n");
        pausar();
        return;
    }

    Veiculo v;
    v.id = total_veiculos + 1;
    v.disponivel = 1;

    limpar_tela();
    printf("========== CADASTRO DE VEICULO ==========\n");

    printf("Placa (ex: ABC1234): ");
    scanf("%9s", v.placa);
    limpar_buffer();

    /* Verifica duplicidade de placa */
    if (buscar_veiculo_placa(v.placa) != NULL) {
        printf("[ERRO] Ja existe um veiculo com essa placa.\n");
        pausar();
        return;
    }

    printf("Modelo: ");
    fgets(v.modelo, sizeof(v.modelo), stdin);
    v.modelo[strcspn(v.modelo, "\n")] = '\0';

    printf("Marca: ");
    fgets(v.marca, sizeof(v.marca), stdin);
    v.marca[strcspn(v.marca, "\n")] = '\0';

    printf("Ano: ");
    scanf("%d", &v.ano);
    limpar_buffer();

    do {
        printf("Valor da diaria (R$): ");
        scanf("%f", &v.diaria);
        limpar_buffer();
        if (v.diaria <= 0)
            printf("[AVISO] Valor deve ser maior que zero.\n");
    } while (v.diaria <= 0);

    veiculos[total_veiculos] = v;
    total_veiculos++;
    salvar_veiculos();

    printf("\n[OK] Veiculo cadastrado com sucesso! ID: %d\n", v.id);
    pausar();
}

void listar_veiculos(void) {
    limpar_tela();
    printf("========== LISTA DE VEICULOS ==========\n");

    if (total_veiculos == 0) {
        printf("Nenhum veiculo cadastrado.\n");
        pausar();
        return;
    }

    printf("%-4s %-10s %-20s %-15s %-5s %-10s %-12s\n",
           "ID", "Placa", "Modelo", "Marca", "Ano", "Diaria", "Status");
    printf("%s\n", "--------------------------------------------------------------------");

    int i;
    for (i = 0; i < total_veiculos; i++) {
        Veiculo *v = &veiculos[i];
        printf("%-4d %-10s %-20s %-15s %-5d R$%-8.2f %-12s\n",
               v->id, v->placa, v->modelo, v->marca, v->ano, v->diaria,
               v->disponivel ? "Disponivel" : "Alugado");
    }

    printf("\nBuscar por placa? (S/N): ");
    char op;
    scanf(" %c", &op);
    limpar_buffer();

    if (op == 'S' || op == 's') {
        char placa[10];
        printf("Digite a placa: ");
        scanf("%9s", placa);
        limpar_buffer();

        Veiculo *v = buscar_veiculo_placa(placa);
        if (v == NULL) {
            printf("[AVISO] Veiculo nao encontrado.\n");
        } else {
            printf("\n--- Detalhes ---\n");
            printf("ID     : %d\n", v->id);
            printf("Placa  : %s\n", v->placa);
            printf("Modelo : %s\n", v->modelo);
            printf("Marca  : %s\n", v->marca);
            printf("Ano    : %d\n", v->ano);
            printf("Diaria : R$ %.2f\n", v->diaria);
            printf("Status : %s\n", v->disponivel ? "Disponivel" : "Alugado");
        }
    }

    pausar();
}

void menu_veiculos(void) {
    int opcao;
    do {
        limpar_tela();
        printf("========== MODULO DE VEICULOS ==========\n");
        printf("1. Cadastrar veiculo\n");
        printf("2. Listar / Buscar veiculos\n");
        printf("0. Voltar\n");
        printf("Opcao: ");
        scanf("%d", &opcao);
        limpar_buffer();

        switch (opcao) {
            case 1: cadastrar_veiculo();  break;
            case 2: listar_veiculos();    break;
            case 0: break;
            default: printf("[AVISO] Opcao invalida.\n"); pausar();
        }
    } while (opcao != 0);
}

/* ===================== MÓDULO DE CLIENTES ===================== */

Cliente *buscar_cliente_cnh(const char *cnh) {
    int i;
    for (i = 0; i < total_clientes; i++) {
        if (strcmp(clientes[i].cnh, cnh) == 0)
            return &clientes[i];
    }
    return NULL;
}

Cliente *buscar_cliente_id(int id) {
    int i;
    for (i = 0; i < total_clientes; i++) {
        if (clientes[i].id == id)
            return &clientes[i];
    }
    return NULL;
}

void cadastrar_cliente(void) {
    if (total_clientes >= MAX_CLIENTES) {
        printf("[AVISO] Limite de clientes atingido.\n");
        pausar();
        return;
    }

    Cliente c;
    c.id = total_clientes + 1;

    limpar_tela();
    printf("========== CADASTRO DE CLIENTE ==========\n");

    printf("Nome completo: ");
    fgets(c.nome, sizeof(c.nome), stdin);
    c.nome[strcspn(c.nome, "\n")] = '\0';

    printf("CNH: ");
    scanf("%19s", c.cnh);
    limpar_buffer();

    if (buscar_cliente_cnh(c.cnh) != NULL) {
        printf("[ERRO] Ja existe um cliente com essa CNH.\n");
        pausar();
        return;
    }

    printf("Telefone: ");
    scanf("%19s", c.telefone);
    limpar_buffer();

    clientes[total_clientes] = c;
    total_clientes++;
    salvar_clientes();

    printf("\n[OK] Cliente cadastrado! ID: %d\n", c.id);
    pausar();
}

