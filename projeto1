/* ===================== MÓDULO DE LOCAÇÕES ===================== */

void registrar_aluguel(void) {
    if (total_locacoes >= MAX_LOCACOES) {
        printf("[AVISO] Limite de locacoes atingido.\n");
        pausar();
        return;
    }

    limpar_tela();
    printf("========== REGISTRAR ALUGUEL ==========\n");

    /* Selecionar veículo */
    char placa[10];
    printf("Placa do veiculo: ");
    scanf("%9s", placa);
    limpar_buffer();

    Veiculo *v = buscar_veiculo_placa(placa);
    if (v == NULL) {
        printf("[ERRO] Veiculo nao encontrado.\n");
        pausar();
        return;
    }
    if (!v->disponivel) {
        printf("[ERRO] Veiculo ja esta alugado.\n");
        pausar();
        return;
    }

    /* Selecionar cliente */
    char cnh[20];
    printf("CNH do cliente: ");
    scanf("%19s", cnh);
    limpar_buffer();

    Cliente *c = buscar_cliente_cnh(cnh);
    if (c == NULL) {
        printf("[ERRO] Cliente nao encontrado.\n");
        pausar();
        return;
    }

    /* Verificar se cliente ja tem locação ativa */
    int i;
    for (i = 0; i < total_locacoes; i++) {
        if (locacoes[i].id_cliente == c->id && locacoes[i].ativa) {
            printf("[ERRO] Cliente ja possui uma locacao ativa.\n");
            pausar();
            return;
        }
    }

    /* Quantidade de dias */
    int dias;
    do {
        printf("Quantidade de dias: ");
        scanf("%d", &dias);
        limpar_buffer();
        if (dias <= 0)
            printf("[AVISO] Numero de dias deve ser maior que zero.\n");
    } while (dias <= 0);

    float total = dias * v->diaria;

    /* Resumo */
    printf("\n--- Resumo da Locacao ---\n");
    printf("Veiculo : %s %s (%s)\n", v->marca, v->modelo, v->placa);
    printf("Cliente : %s (CNH: %s)\n", c->nome, c->cnh);
    printf("Dias    : %d\n", dias);
    printf("Diaria  : R$ %.2f\n", v->diaria);
    printf("TOTAL   : R$ %.2f\n", total);

    printf("\nConfirmar? (S/N): ");
    char op;
    scanf(" %c", &op);
    limpar_buffer();

    if (op != 'S' && op != 's') {
        printf("Operacao cancelada.\n");
        pausar();
        return;
    }

    /* Registrar locação */
    Locacao l;
    l.id          = total_locacoes + 1;
    l.id_veiculo  = v->id;
    l.id_cliente  = c->id;
    l.dias        = dias;
    l.valor_total = total;
    l.ativa       = 1;
    strcpy(l.data_devolucao_real, "---");

    data_hoje(l.data_retirada, sizeof(l.data_retirada));

    /* Data prevista de devolução (simplificada: apenas registra os dias) */
    snprintf(l.data_devolucao_prev, sizeof(l.data_devolucao_prev),
             "em %d dia(s)", dias);

    /* Atualizar status do veículo */
    v->disponivel = 0;

    locacoes[total_locacoes] = l;
    total_locacoes++;

    salvar_veiculos();
    salvar_locacoes();

    printf("\n[OK] Locacao registrada! ID: %d\n", l.id);
    pausar();
}

void registrar_devolucao(void) {
    limpar_tela();
    printf("========== REGISTRAR DEVOLUCAO ==========\n");

    /* Listar locações ativas para facilitar */
    int encontrou = 0;
    int i;
    for (i = 0; i < total_locacoes; i++) {
        if (locacoes[i].ativa) {
            if (!encontrou) {
                printf("Locacoes ativas:\n");
                printf("%-4s %-10s %-30s %-12s %-10s\n",
                       "ID", "Placa", "Cliente", "Retirada", "Total");
                printf("%s\n", "------------------------------------------------------------");
                encontrou = 1;
            }
            Veiculo *v = buscar_veiculo_id(locacoes[i].id_veiculo);
            Cliente *c = buscar_cliente_id(locacoes[i].id_cliente);
            printf("%-4d %-10s %-30s %-12s R$%.2f\n",
                   locacoes[i].id,
                   v ? v->placa : "?",
                   c ? c->nome  : "?",
                   locacoes[i].data_retirada,
                   locacoes[i].valor_total);
        }
    }

    if (!encontrou) {
        printf("Nenhuma locacao ativa no momento.\n");
        pausar();
        return;
    }

    int id_loc;
    printf("\nID da locacao para devolver: ");
    scanf("%d", &id_loc);
    limpar_buffer();

    /* Buscar locação */
    Locacao *loc = NULL;
    for (i = 0; i < total_locacoes; i++) {
        if (locacoes[i].id == id_loc && locacoes[i].ativa) {
            loc = &locacoes[i];
            break;
        }
    }

    if (loc == NULL) {
        printf("[ERRO] Locacao ativa nao encontrada com esse ID.\n");
        pausar();
        return;
    }

    Veiculo *v = buscar_veiculo_id(loc->id_veiculo);
    Cliente *c = buscar_cliente_id(loc->id_cliente);

    printf("\n--- Confirmacao de Devolucao ---\n");
    if (v) printf("Veiculo : %s %s (%s)\n", v->marca, v->modelo, v->placa);
    if (c) printf("Cliente : %s\n", c->nome);
    printf("Valor cobrado: R$ %.2f\n", loc->valor_total);

    printf("\nConfirmar devolucao? (S/N): ");
    char op;
    scanf(" %c", &op);
    limpar_buffer();

    if (op != 'S' && op != 's') {
        printf("Operacao cancelada.\n");
        pausar();
        return;
    }

    /* Registrar devolução */
    data_hoje(loc->data_devolucao_real, sizeof(loc->data_devolucao_real));
    loc->ativa = 0;

    if (v) v->disponivel = 1;

    salvar_veiculos();
    salvar_locacoes();

    printf("\n[OK] Devolucao registrada em %s.\n", loc->data_devolucao_real);
    pausar();
}

void listar_locacoes_ativas(void) {
    limpar_tela();
    printf("========== LOCACOES ATIVAS ==========\n");

    int encontrou = 0;
    int i;
    for (i = 0; i < total_locacoes; i++) {
        if (locacoes[i].ativa) {
            if (!encontrou) {
                printf("%-4s %-10s %-30s %-12s %-5s %-10s\n",
                       "ID", "Placa", "Cliente", "Retirada", "Dias", "Total");
                printf("%s\n", "--------------------------------------------------------------");
                encontrou = 1;
            }
            Veiculo *v = buscar_veiculo_id(locacoes[i].id_veiculo);
            Cliente *c = buscar_cliente_id(locacoes[i].id_cliente);
            printf("%-4d %-10s %-30s %-12s %-5d R$%.2f\n",
                   locacoes[i].id,
                   v ? v->placa : "?",
                   c ? c->nome  : "?",
                   locacoes[i].data_retirada,
                   locacoes[i].dias,
                   locacoes[i].valor_total);
        }
    }

    if (!encontrou)
        printf("Nenhuma locacao ativa.\n");

    pausar();
}

void menu_locacoes(void) {
    int opcao;
    do {
        limpar_tela();
        printf("========== MODULO DE LOCACOES ==========\n");
        printf("1. Registrar aluguel\n");
        printf("2. Registrar devolucao\n");
        printf("3. Ver locacoes ativas\n");
        printf("0. Voltar\n");
