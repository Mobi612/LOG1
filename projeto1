        }
    } while (opcao != 0);
}

/* ===================== RELATÓRIOS ===================== */

void relatorio_veiculos_disponiveis(void) {
    limpar_tela();
    printf("========== VEICULOS DISPONIVEIS ==========\n");

    int encontrou = 0;
    int i;
    for (i = 0; i < total_veiculos; i++) {
        if (veiculos[i].disponivel) {
            if (!encontrou) {
                printf("%-4s %-10s %-20s %-15s %-5s %-10s\n",
                       "ID", "Placa", "Modelo", "Marca", "Ano", "Diaria");
                printf("%s\n", "--------------------------------------------------------------");
                encontrou = 1;
            }
            Veiculo *v = &veiculos[i];
            printf("%-4d %-10s %-20s %-15s %-5d R$%.2f\n",
                   v->id, v->placa, v->modelo, v->marca, v->ano, v->diaria);
        }
    }

    if (!encontrou)
        printf("Nenhum veiculo disponivel no momento.\n");

    pausar();
}

void relatorio_historico_locacoes(void) {
    limpar_tela();
    printf("========== HISTORICO DE LOCACOES ==========\n");

    if (total_locacoes == 0) {
        printf("Nenhuma locacao registrada.\n");
        pausar();
        return;
    }

    printf("%-4s %-10s %-25s %-12s %-12s %-10s %-8s\n",
           "ID", "Placa", "Cliente", "Retirada", "Devolucao", "Total", "Status");
    printf("%s\n", "------------------------------------------------------------------------------");

    int i;
    for (i = 0; i < total_locacoes; i++) {
        Locacao *l = &locacoes[i];
        Veiculo *v = buscar_veiculo_id(l->id_veiculo);
        Cliente *c = buscar_cliente_id(l->id_cliente);

        printf("%-4d %-10s %-25s %-12s %-12s R$%-7.2f %-8s\n",
               l->id,
               v ? v->placa : "?",
               c ? c->nome  : "?",
               l->data_retirada,
               l->ativa ? l->data_devolucao_prev : l->data_devolucao_real,
               l->valor_total,
               l->ativa ? "Ativa" : "Encerrada");
    }

    pausar();
}

void menu_relatorios(void) {
    int opcao;
    do {
        limpar_tela();
        printf("========== RELATORIOS ==========\n");
        printf("1. Veiculos disponiveis\n");
        printf("2. Historico de locacoes\n");
        printf("0. Voltar\n");
        printf("Opcao: ");
        scanf("%d", &opcao);
        limpar_buffer();

        switch (opcao) {
            case 1: relatorio_veiculos_disponiveis(); break;
            case 2: relatorio_historico_locacoes();   break;
            case 0: break;
            default: printf("[AVISO] Opcao invalida.\n"); pausar();
        }
    } while (opcao != 0);
}

