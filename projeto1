    char op;
    scanf(" %c", &op);
    limpar_buffer();

    if (op == 'S' || op == 's') {
        char cnh[20];
        printf("Digite a CNH: ");
        scanf("%19s", cnh);
        limpar_buffer();

        Cliente *c = buscar_cliente_cnh(cnh);
        if (c == NULL) {
            printf("[AVISO] Cliente nao encontrado.\n");
        } else {
            printf("\n--- Detalhes ---\n");
            printf("ID       : %d\n", c->id);
            printf("Nome     : %s\n", c->nome);
            printf("CNH      : %s\n", c->cnh);
            printf("Telefone : %s\n", c->telefone);
        }
